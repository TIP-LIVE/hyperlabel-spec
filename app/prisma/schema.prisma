// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum LabelStatus {
  INVENTORY // In warehouse, not sold
  SOLD // Sold but not activated
  ACTIVE // Activated and tracking
  DEPLETED // Battery dead
}

enum ShipmentStatus {
  PENDING // Created but not yet in transit
  IN_TRANSIT // Label activated, cargo moving
  DELIVERED // Arrived at destination
  CANCELLED // Shipment cancelled
}

enum ShipmentType {
  CARGO_TRACKING // Customer tracks their cargo with a label
  LABEL_DISPATCH // TIP ships labels from warehouse to customer
}

enum OrderStatus {
  PENDING // Awaiting payment
  PAID // Payment received
  SHIPPED // Labels shipped to customer
  DELIVERED // Labels delivered to customer
  CANCELLED // Order cancelled
}

enum OrderSource {
  STRIPE          // Created by Stripe webhook (paid checkout)
  INVOICE         // Admin-created invoice billed outside Stripe (grants dispatch capacity)
  LABELS_REGISTER // Admin/user registering physical labels already in hand (does NOT grant capacity)
}

enum LocationSource {
  GPS // Device firmware location report (currently cell tower, name kept for backward compat)
  CELL_TOWER // Onomondo Location Update webhook (cell tower triangulation)
}

/// Per-user cadence for the consolidated shipment status digest.
/// - DAILY: one digest per day if any shipments need attention (default for new users)
/// - WEEKLY: one digest on Mondays (UTC), even if items are available mid-week
/// - OFF: never send a digest (staff/admin accounts default to this in the Clerk webhook)
enum DigestCadence {
  OFF
  WEEKLY
  DAILY
}

// ============================================
// MODELS
// ============================================

/// Users - synced from Clerk via webhooks
model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique @map("clerk_id")
  email     String   @unique
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  imageUrl  String?  @map("image_url")
  role      String   @default("user") // user, admin
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Notification preferences
  notifyLabelActivated Boolean @default(true) @map("notify_label_activated")
  notifyLowBattery     Boolean @default(true) @map("notify_low_battery")
  notifyNoSignal       Boolean @default(true) @map("notify_no_signal")
  notifyDelivered      Boolean @default(true) @map("notify_delivered")
  notifyOrderShipped   Boolean @default(true) @map("notify_order_shipped")
  notifyShipmentStuck  Boolean @default(true) @map("notify_shipment_stuck")
  notifyReminders      Boolean @default(true) @map("notify_reminders")

  // Consolidated "shipment status" digest cadence. Replaces per-alert crons
  // (no-signal, stuck, pending). Staff accounts (isAdminEmail) default to OFF
  // in the Clerk webhook so internal test shipments don't blast their inbox.
  digestCadence DigestCadence @default(DAILY) @map("digest_cadence")

  // Relations
  orders         Order[]
  shipments      Shipment[]
  notifications  Notification[]
  savedAddresses SavedAddress[]

  @@map("users")
}

/// Labels - physical tracking devices with cellular connectivity.
/// A label can belong to multiple organisations via OrderLabel (many-to-many with Order).
model Label {
  id                    String      @id @default(cuid())
  deviceId              String      @unique @map("device_id") // e.g. TIP-001, HL-001234 (legacy internal handle)
  counter               Int?        @unique // sequential 1..99999, assigned at generation
  displayId             String?     @unique @map("display_id") // NNNNNYYYY = counter(5) + imei[-4], user-facing
  imei                  String?     @unique // Device IMEI
  iccid                 String?     @unique // SIM card ID
  status                LabelStatus @default(INVENTORY)
  batteryPct            Int?        @map("battery_pct")
  firmwareVersion       String?     @map("firmware_version")
  activatedAt           DateTime?   @map("activated_at")
  manufacturedAt        DateTime?   @map("manufactured_at")
  claimToken            String?     @unique @map("claim_token")
  claimExpiresAt        DateTime?   @map("claim_expires_at")
  firstUnlinkedReportAt DateTime?   @map("first_unlinked_report_at")
  lastSeenAt            DateTime?   @map("last_seen_at")
  lastLatitude          Float?      @map("last_latitude")
  lastLongitude         Float?      @map("last_longitude")
  lastAccuracy          Float?      @map("last_accuracy")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  // Relations (many-to-many with Order so a label can be in multiple orgs)
  orderLabels    OrderLabel[]
  shipments      Shipment[]
  shipmentLabels ShipmentLabel[] // For LABEL_DISPATCH multi-label shipments
  locations      LocationEvent[]

  @@map("labels")
}

/// Shipments - cargo being tracked or label dispatches
model Shipment {
  id                    String         @id @default(cuid())
  type                  ShipmentType   @default(CARGO_TRACKING)
  name                  String? // Cargo description
  originAddress         String?        @map("origin_address")
  originLat             Float?         @map("origin_lat")
  originLng             Float?         @map("origin_lng")
  destinationAddress    String?        @map("destination_address")
  destinationLat        Float?         @map("destination_lat")
  destinationLng        Float?         @map("destination_lng")
  destinationName       String?        @map("destination_name")
  destinationLine1      String?        @map("destination_line1")
  destinationLine2      String?        @map("destination_line2")
  destinationCity       String?        @map("destination_city")
  destinationState      String?        @map("destination_state")
  destinationPostalCode String?        @map("destination_postal_code")
  destinationCountry    String?        @map("destination_country") @db.Char(2)
  receiverFirstName     String?        @map("receiver_first_name")
  receiverLastName      String?        @map("receiver_last_name")
  addressSubmittedAt    DateTime?      @map("address_submitted_at")
  shareLinkExpiresAt    DateTime?      @map("share_link_expires_at")
  status                ShipmentStatus @default(PENDING)
  shareCode             String         @unique @map("share_code") // Public tracking URL code
  shareEnabled          Boolean        @default(true) @map("share_enabled")
  consigneeEmail        String?        @map("consignee_email") // Recipient's email for status updates
  consigneePhone        String?        @map("consignee_phone") // Recipient's phone number
  consigneeUnsubscribed Boolean        @default(false) @map("consignee_unsubscribed") // Consignee opted out of emails
  photoUrls             String[]       @map("photo_urls") // Cargo photos
  labelCount            Int?           @map("label_count") // Expected label count for LABEL_DISPATCH (labels linked at scan time)
  orderId               String?        @map("order_id") // Source order for LABEL_DISPATCH
  order                 Order?         @relation(fields: [orderId], references: [id])
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")
  deliveredAt           DateTime?      @map("delivered_at")

  // Digest backoff: how many times this shipment has appeared in a status
  // digest for its *current* problem period. Reset to 0 when the issue resolves
  // (PENDING → IN_TRANSIT, label recovers from silence, auto-delivery, etc.).
  // After digestCount exceeds the backoff table the shipment falls silent.
  digestCount  Int       @default(0) @map("digest_count")
  lastDigestAt DateTime? @map("last_digest_at")

  // Organization scoping (from Clerk Organizations)
  orgId String? @map("org_id")

  // Relations
  userId         String          @map("user_id")
  user           User            @relation(fields: [userId], references: [id])
  labelId        String?         @map("label_id") // Primary label (CARGO_TRACKING, nullable for LABEL_DISPATCH)
  label          Label?          @relation(fields: [labelId], references: [id])
  shipmentLabels ShipmentLabel[] // Multiple labels (used for LABEL_DISPATCH)
  locations      LocationEvent[]

  @@index([orgId])
  @@index([orderId])
  @@map("shipments")
}

/// LocationEvent - location data points from devices
model LocationEvent {
  id            String         @id @default(cuid())
  latitude      Float
  longitude     Float
  accuracyM     Int?           @map("accuracy_m")
  batteryPct    Int?           @map("battery_pct")
  altitude      Float?
  speed         Float?
  recordedAt    DateTime       @map("recorded_at") // When device recorded
  receivedAt    DateTime       @default(now()) @map("received_at") // When server received
  isOfflineSync Boolean        @default(false) @map("is_offline_sync")
  source        LocationSource @default(GPS) @map("source")
  eventType     String?        @map("event_type") // Onomondo event type: 'location', 'network-registration', etc.

  // Cell tower backup location (from Onomondo)
  cellLatitude  Float? @map("cell_latitude")
  cellLongitude Float? @map("cell_longitude")

  // Reverse-geocoded address (populated server-side at ingest)
  geocodedCity        String?   @map("geocoded_city")
  geocodedArea        String?   @map("geocoded_area") // Suburb/neighbourhood for detail view
  geocodedCountry     String?   @map("geocoded_country")
  geocodedCountryCode String?   @map("geocoded_country_code")
  // Timestamp of the last geocode attempt (success OR failure). NULL means
  // "never tried yet" → UI shows "Locating…" instead of raw coords. When set
  // but geocodedCity is still NULL, the attempt failed and the backfill cron
  // waits ≥24h before retrying (avoids hammering Nominatim with permanently
  // unresolvable coords).
  geocodedAt          DateTime? @map("geocoded_at")

  // Soft-exclude: reason the event was marked invalid (e.g. "teleportation", "test_data").
  // NULL = valid event. Excluded events are filtered out of all user-facing queries.
  excludedReason String? @map("excluded_reason")

  // Relations
  labelId    String    @map("label_id")
  label      Label     @relation(fields: [labelId], references: [id])
  shipmentId String?   @map("shipment_id")
  shipment   Shipment? @relation(fields: [shipmentId], references: [id])

  @@unique([labelId, recordedAt, latitude, longitude, source], name: "location_events_dedup")
  @@index([labelId, recordedAt])
  @@index([shipmentId, recordedAt])
  @@map("location_events")
}

/// Orders - purchase records
model Order {
  id              String       @id @default(cuid())
  stripePaymentId String?      @unique @map("stripe_payment_id")
  stripeSessionId String?      @unique @map("stripe_session_id")
  status          OrderStatus  @default(PENDING)
  source          OrderSource? @map("source") // null = legacy rows; else identifies creation path
  totalAmount     Int          @map("total_amount") // In cents
  currency        String       @default("GBP")
  quantity        Int // Number of labels

  // Shipping info
  shippingAddress Json?     @map("shipping_address")
  trackingNumber  String?   @map("tracking_number") // DHL/FedEx tracking
  shippedAt       DateTime? @map("shipped_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Organization scoping (from Clerk Organizations)
  orgId String? @map("org_id")

  // Relations
  userId      String       @map("user_id")
  user        User         @relation(fields: [userId], references: [id])
  orderLabels OrderLabel[]
  dispatches  Shipment[]

  @@index([orgId])
  @@map("orders")
}

/// Join table: a label can be in multiple orders (thus multiple orgs)
model OrderLabel {
  orderId String @map("order_id")
  labelId String @map("label_id")
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([orderId, labelId])
  @@map("order_labels")
}

/// Join table: labels included in a shipment (used for LABEL_DISPATCH type)
model ShipmentLabel {
  shipmentId String   @map("shipment_id")
  labelId    String   @map("label_id")
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  label      Label    @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([shipmentId, labelId])
  @@map("shipment_labels")
}

/// Pricing for label packs sold via Stripe checkout. Edited via /admin/pricing.
model LabelPack {
  key         String   @id // "starter" | "team" | "volume"
  name        String
  description String
  quantity    Int
  priceCents  Int      @map("price_cents")
  popular     Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("label_packs")
}

/// Organisation-level settings (Clerk org ID)
model OrgSettings {
  id                        String   @id @default(cuid())
  orgId                     String   @unique @map("org_id")
  allowLabelsInMultipleOrgs Boolean  @default(false) @map("allow_labels_in_multiple_orgs")
  defaultDispatchAddressId  String?  @map("default_dispatch_address_id")
  noSignalHours             Int      @default(48) @map("no_signal_hours")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  @@map("org_settings")
}

/// SavedAddress - user's saved shipping addresses for quick reuse
model SavedAddress {
  id         String   @id @default(cuid())
  label      String // Nickname: "Home", "Warehouse Berlin"
  name       String // Recipient full name
  line1      String
  line2      String?
  city       String
  state      String?
  postalCode String   @map("postal_code")
  country    String   @db.Char(2) // ISO 2-letter country code
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Organization scoping (from Clerk Organizations)
  orgId String? @map("org_id")

  // Relations
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, orgId])
  @@map("saved_addresses")
}

/// Notification - email/push notifications sent
model Notification {
  id      String   @id @default(cuid())
  type    String // label_activated, low_battery, no_signal, shipment_delivered, order_shipped
  message String? // Summary or JSON metadata
  read    Boolean  @default(false)
  sentAt  DateTime @default(now()) @map("sent_at")

  // Organization scoping (from Clerk Organizations)
  orgId String? @map("org_id")

  // Relations
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId, orgId, sentAt])
  @@map("notifications")
}

// ============================================
// WEBHOOK DEBUG LOGS
// ============================================

model WebhookLog {
  id               String   @id @default(cuid())
  endpoint         String // "connector" | "location-update"
  method           String   @default("POST")
  headers          Json // Sanitized (auth values redacted)
  body             Json // Raw JSON payload
  ipAddress        String?  @map("ip_address")
  statusCode       Int?     @map("status_code")
  processingResult Json?    @map("processing_result")
  iccid            String?
  eventType        String?  @map("event_type")
  durationMs       Int?     @map("duration_ms")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([iccid])
  @@index([endpoint])
  @@map("webhook_logs")
}

model CronExecutionLog {
  id         String    @id @default(cuid())
  jobName    String    @map("job_name")
  status     String    @default("running") // "running" | "success" | "error"
  durationMs Int?      @map("duration_ms")
  metrics    Json? // The cron's response metrics
  error      String?
  startedAt  DateTime  @default(now()) @map("started_at")
  finishedAt DateTime? @map("finished_at")

  @@index([jobName, startedAt])
  @@index([startedAt])
  @@map("cron_execution_logs")
}

// ============================================
// RESEARCH HUB ENUMS
// ============================================

enum ResearchPersona {
  CONSIGNEE
  FORWARDER
  SHIPPER
}

enum ResearchLeadStatus {
  SOURCED
  CONTACTED
  SCREENED
  SCHEDULED
  COMPLETED
  ANALYSED
  DECLINED
  NO_SHOW
}

enum ResearchTaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum ResearchTaskCategory {
  OUTREACH
  SCHEDULING
  FOLLOW_UP
  GIFT_CARD
  ANALYSIS
  REVIEW
}

enum ScriptStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  ARCHIVED
}

enum InterviewStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ============================================
// RESEARCH HUB MODELS
// ============================================

/// ResearchLead - people we want to interview for user research
model ResearchLead {
  id             String             @id @default(cuid())
  name           String
  email          String?
  linkedIn       String?            @map("linked_in")
  company        String?
  role           String?
  persona        ResearchPersona
  status         ResearchLeadStatus @default(SOURCED)
  source         String? // linkedin, referral, cold-email, respondent.io, personal-network
  referredBy     String?            @map("referred_by") // Lead ID of referrer
  screeningNotes String?            @map("screening_notes")
  pilotInterest  Int?               @map("pilot_interest") // 1-5 scale
  giftCardSent   Boolean            @default(false) @map("gift_card_sent")
  giftCardType   String?            @map("gift_card_type") // e.g. "amazon-30-gbp"
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  // Relations
  tasks      ResearchTask[]
  interviews ResearchInterview[]
  emailLogs  ResearchEmailLog[]

  @@index([status])
  @@index([persona])
  @@map("research_leads")
}

/// ResearchTask - tasks generated during the research process
model ResearchTask {
  id          String               @id @default(cuid())
  title       String
  description String?
  status      ResearchTaskStatus   @default(TODO)
  dueDate     DateTime?            @map("due_date")
  assignee    String? // userId
  category    ResearchTaskCategory
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  // Relations
  leadId String?       @map("lead_id")
  lead   ResearchLead? @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([leadId])
  @@map("research_tasks")
}

/// ResearchScript - interview question sets with CEO review workflow
model ResearchScript {
  id          String          @id @default(cuid())
  persona     ResearchPersona
  version     Int             @default(1)
  title       String
  sections    Json // [{ title, duration, questions: [{ text, probes[] }] }]
  status      ScriptStatus    @default(DRAFT)
  reviewedBy  String?         @map("reviewed_by")
  reviewNotes String?         @map("review_notes")
  reviewedAt  DateTime?       @map("reviewed_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@index([persona])
  @@index([status])
  @@map("research_scripts")
}

/// ResearchEmailTemplate - email templates with CEO review workflow
model ResearchEmailTemplate {
  id          String           @id @default(cuid())
  type        String // outreach, scheduled, reminder, thank_you, referral
  persona     ResearchPersona? // null = all personas, or persona-specific
  subject     String
  body        String // The email body text (plain text, supports line breaks)
  status      ScriptStatus     @default(DRAFT)
  reviewedBy  String?          @map("reviewed_by")
  reviewNotes String?          @map("review_notes")
  reviewedAt  DateTime?        @map("reviewed_at")
  version     Int              @default(1)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@unique([type, persona])
  @@index([type])
  @@index([status])
  @@map("research_email_templates")
}

/// ResearchInterview - a scheduled or completed interview with a lead
model ResearchInterview {
  id                String          @id @default(cuid())
  leadId            String          @map("lead_id")
  lead              ResearchLead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  scheduledAt       DateTime?       @map("scheduled_at")
  completedAt       DateTime?       @map("completed_at")
  duration          Int? // minutes
  calendarEventId   String?         @map("calendar_event_id")
  recordingUrl      String?         @map("recording_url")
  transcriptUrl     String?         @map("transcript_url")
  notes             Json?
  keyQuotes         Json?           @map("key_quotes")
  hypothesisSignals Json?           @map("hypothesis_signals")
  status            InterviewStatus @default(SCHEDULED)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  @@index([leadId])
  @@index([status])
  @@index([scheduledAt])
  @@map("research_interviews")
}

/// ResearchEmailLog - tracks all research emails sent to leads
model ResearchEmailLog {
  id      String       @id @default(cuid())
  leadId  String       @map("lead_id")
  lead    ResearchLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type    String // outreach, scheduled, reminder, thank_you, referral
  subject String
  to      String
  sentAt  DateTime     @default(now()) @map("sent_at")

  @@index([leadId])
  @@index([type])
  @@map("research_email_logs")
}

/// ResearchHypothesis - what we're trying to validate through interviews
model ResearchHypothesis {
  id            String   @id @default(cuid())
  code          String   @unique // "H1", "H2", etc.
  statement     String
  successSignal String   @map("success_signal")
  validating    Int      @default(0)
  neutral       Int      @default(0)
  invalidating  Int      @default(0)
  verdict       String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("research_hypotheses")
}

{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=60, stale-while-revalidate=60" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/check-delivery",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/check-battery",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/check-signals",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/check-stuck",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/check-reminders",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/cleanup-data",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/check-unclaimed-labels",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/backfill-geocode",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/watchdog",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/research-reminders",
      "schedule": "30 7 * * *"
    },
    {
      "path": "/api/cron/research-followup",
      "schedule": "30 9 * * *"
    },
    {
      "path": "/api/cron/research-referral",
      "schedule": "30 10 * * *"
    },
    {
      "path": "/api/cron/research-stale-leads",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/research-gift-cards",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/sync-utec-battery",
      "schedule": "17 */2 * * *"
    }
  ]
}
